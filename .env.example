## DocumentDB connection
# Any MongoDB-wire-compatible URI works. Examples:
#   mongodb://user:pass@localhost:10260/?tls=false
#   mongodb+srv://user:pass@cluster.example.cosmos.azure.com/
# Note: when connecting to the dockerized stack from compose.yml /
# compose.full.yml, the documentdb-local image enforces TLS, so use:
#   mongodb://localadmin:Admin100@localhost:10260/?directConnection=true&tls=true&tlsInsecure=true
DOCUMENTDB_URI=mongodb://localadmin:Admin100@localhost:10260/?tls=false
# Fallback name read if DOCUMENTDB_URI is unset:
# MONGODB_URI=

## Database name used for both the knowledge-graph and the session-history mirror.
DOCUMENTDB_DB=copilot_memory

## Path to Copilot CLI's local SQLite session store (read-only by us).
## Default resolves to $HOME/.copilot/session-store.db.
## In compose.full.yml the sync daemon container reads
## /copilot/session-store.db, where /copilot is a read-only bind of
## $COPILOT_DIR (see below).
# COPILOT_SESSION_STORE=/Users/me/.copilot/session-store.db

## Host directory bind-mounted as /copilot:ro inside the
## documentdb-memory-sync container. Override only if your Copilot CLI
## lives somewhere other than $HOME/.copilot.
# COPILOT_DIR=/Users/me/.copilot

## Logging level: trace, debug, info, warn, error, fatal.
MEMORY_LOG_LEVEL=info

## Sync daemon polling interval (used by `documentdb-memory sessions sync --watch`).
## Accepts durations like 10s, 30s, 1m, 5m.
SYNC_INTERVAL=30s

## When set to "1" or "true", the user intends to host-bind the
## documentdbfuse mount under ./mnt/db. This variable is a documentation
## marker — to actually activate the bind, also chain the override file
## by setting COMPOSE_FILE below.
## Requires macFUSE on macOS or fuse3 on Linux.
FUSE_HOST_BIND=0

## Compose file chain. Uncomment to make `docker compose ...` (with no
## `-f`) auto-pick up the FUSE host-bind override. The colon-separated
## list mirrors what you'd pass to `-f` on the command line.
# COMPOSE_FILE=compose.yml:compose.fuse-host-bind.yml
# COMPOSE_FILE=compose.full.yml:compose.fuse-host-bind.yml
